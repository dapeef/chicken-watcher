# Set to "dev" for local development (uses SQLite, no Postgres needed).
# Leave unset or set to "prod" in production (Docker Compose sets it explicitly).
DJANGO_ENV=dev
DJANGO_SECRET_KEY=

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# RFID readers — up to 4 per nesting box (leave blank if not connected)
# Which modem-control line on the USB-serial adapter is wired to the RFID
# PCB's RST pin, and whether to pulse it:
#   dtr  — pulse DTR after each read (default; suits adapters labelled "DTE")
#   rts  — pulse RTS after each read (older adapters)
#   none — hold the line permanently low; no pulse sent. Eliminates
#           modem-control USB transfers (useful on marginal hubs) at the
#           cost of not being able to re-read a stationary tag.
RFID_RESET_LINE=dtr
RFID_PORT_LEFT_1= # eg /dev/serial/by-id/usb-FTDI_FT232R_USB_UART_BG01PVA3-if00-port0
RFID_PORT_LEFT_2=
RFID_PORT_LEFT_3=
RFID_PORT_LEFT_4=
RFID_PORT_RIGHT_1=
RFID_PORT_RIGHT_2=
RFID_PORT_RIGHT_3=
RFID_PORT_RIGHT_4=

CAMERA_DEVICE= # prefer a stable by-id path, eg /dev/v4l/by-id/usb-Arducam_Technology_Co.__Ltd._USB_Camera_SN0001-video-index0

BEAM_BREAK_GPIO_LEFT=
BEAM_BREAK_GPIO_RIGHT=

# Coop location — used for sunrise/sunset calculation on the timeline
COOP_LATITUDE=
COOP_LONGITUDE=

# Seconds between RFID reads for the same chicken+box within which the reads
# are merged into the same presence period rather than starting a new one.
# Defaults to 60 if unset.
NESTING_BOX_PRESENCE_TIMEOUT_SECONDS=
